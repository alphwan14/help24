# =============================================================================
# Help24 Backend (NestJS) — environment template
# =============================================================================
# Copy to `.env` and fill in real values. NEVER commit `.env` — only this
# `.env.example` belongs in git. On Render, set these as dashboard env vars
# (no file is uploaded); this file documents exactly what the service needs.
#
# NOTE ON NAMES: variable names below match what the code actually reads
# (see backend/src/config/configuration.ts). The M-Pesa / Daraja keys are
# prefixed MPESA_ (not DARAJA_), and there is NO JWT_SECRET — admin auth uses
# hashed opaque tokens, not JWTs. Do not rename these or the server will fail
# its startup config validation.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Comma-separated list of allowed browser origins for CORS. Leave UNSET to allow
# all origins (current default). In production, restrict to the dashboard origin:
#   CORS_ORIGINS=https://help24-admin-dashboard.vercel.app
CORS_ORIGINS=

# ── Supabase ──────────────────────────────────────────────────────────────────
# service_role key — Settings → API → service_role. Server-side ONLY, full access.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin system ──────────────────────────────────────────────────────────────
# Origin of the admin DASHBOARD (Next.js frontend) — used to build invite links.
#   dev:  http://localhost:3001
#   prod: https://help24-admin-dashboard.vercel.app
ADMIN_DASHBOARD_URL=https://help24-admin-dashboard.vercel.app
# Verbose admin-auth logging + /admin/_diag endpoint. Keep false in production.
ADMIN_AUTH_DEBUG=false

# ── M-Pesa Daraja (STK push) ──────────────────────────────────────────────────
MPESA_ENV=production                                  # sandbox | production
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=your-shortcode                        # sandbox default: 174379
MPESA_PASSKEY=your-lipa-na-mpesa-passkey
# Callbacks MUST be HTTPS and contain the exact path (validated at startup).
MPESA_CALLBACK_URL=https://api.help24.app/mpesa/stk-callback

# ── M-Pesa B2C (provider payouts) ─────────────────────────────────────────────
MPESA_B2C_INITIATOR_NAME=your-api-initiator-name
MPESA_B2C_SECURITY_CREDENTIAL=your-encrypted-security-credential
MPESA_B2C_RESULT_URL=https://api.help24.app/mpesa/b2c-callback
MPESA_B2C_TIMEOUT_URL=https://api.help24.app/mpesa/b2c-timeout

# ── Firebase Admin (push notifications) ───────────────────────────────────────
# From the Firebase service-account JSON. Keep the private key's literal \n
# escapes intact (the code converts them back to newlines).
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
