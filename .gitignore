# ═══════════════════════════════════════════════════════════
# Help24 Monorepo — Root .gitignore
# Structure: mobile-app/ | backend/ | admin-dashboard/ | supabase/
# ═══════════════════════════════════════════════════════════

# ── OS Generated ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ── IDE & Editors ─────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.iml
*.ipr
*.iws
.cursor/

# ── Environment & Secrets (NEVER COMMIT) ─────────────────
.env
.env.*
*.env
.envrc
secrets.json
credentials.json
# Firebase credentials — store securely outside repo
google-services.json
GoogleService-Info.plist
firebase_options.dart

# ── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ════════════════════════════════════════════════════════════
