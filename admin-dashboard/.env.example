# =============================================================================
# Help24 Admin Dashboard (Next.js) — environment template
# =============================================================================
# Copy to `.env.local` for dev. NEVER commit `.env.local` — only this
# `.env.example` belongs in git. On Vercel, set these as Project → Settings →
# Environment Variables.
# =============================================================================

# Origin of the NestJS backend the dashboard + accept-invite flow call.
#   dev:  http://localhost:3000
#   prod: https://help24-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=https://help24-backend.onrender.com

# ── Supabase ──────────────────────────────────────────────────────────────────
# Public (browser-safe) project URL + anon/publishable key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# service_role key — SERVER-ONLY (used by server components/actions via
# createServiceClient). Never exposed to the browser; do NOT prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
